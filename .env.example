# =============================================================================
# AI-Library Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=AI_Library
APP_ENV=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
ENABLE_DEV_MOCK_AUTH=True

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_SECRET_KEY=your-admin-secret-key-change-this

INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=changethispassword

# -----------------------------------------------------------------------------
# URLs & CORS
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_library
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DB_SSL_VERIFY=False

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# OpenAI API
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Google Cloud Services
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_TTS_API_KEY=your-google-tts-api-key-here
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# -----------------------------------------------------------------------------
# Stripe Payment Processing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID=price_your-stripe-price-id
STRIPE_PRICE_PRO_MONTHLY=price_your-pro-monthly-price-id
STRIPE_PORTAL_LINK=https://billing.stripe.com/p/login/your-portal-link

# -----------------------------------------------------------------------------
# Email / SMTP Configuration
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-app-password
SMTP_TLS=True
SMTP_SSL=False
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=AI Library
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# -----------------------------------------------------------------------------
# Cloud Storage
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PRESIGN_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,epub,txt

# -----------------------------------------------------------------------------
# Vector Database & RAG Settings
# -----------------------------------------------------------------------------
VECTOR_DB_PATH=vector_db
CHROMA_DB_PATH=chroma_db
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CONTEXT_LENGTH=4000
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-api-key

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
