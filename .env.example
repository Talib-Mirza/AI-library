# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

APP_NAME=Thesyx
APP_ENV=development
DEBUG=true

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================

SECRET_KEY=change-me-32+chars
JWT_SECRET_KEY=change-me-32+chars

# Optional initial admin bootstrap (use script app/scripts/set_admin_user.py)
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=please-change-me

# =============================================================================
# DATABASE & CACHE
# =============================================================================

# AsyncPG URL for app runtime
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/ai_library
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# OpenAI / Google APIs
OPENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_TTS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=gcp-key.json

# Google OAuth (frontend login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# =============================================================================
# ORIGINS & FILES
# =============================================================================

FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:8000
UPLOAD_DIR=uploads
VECTOR_DB_PATH=vector_db

# Email/SMTP (optional; dev prints to console if omitted)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_SSL=false
MAIL_FROM=
MAIL_FROM_NAME=Thesyx 